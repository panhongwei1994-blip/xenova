---
import Input from '@/components/ui/form/Input/Input.astro';
import Textarea from '@/components/ui/form/Textarea/Textarea.astro';
import Button from '@/components/ui/form/Button/Button.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import { cn } from '@/lib/cn';
import { t } from '@/config/i18n.config';

interface Props {
  action?: string;
  successMessage?: string;
  class?: string;
}

const {
  action = '/api/contact',
  successMessage = t('contact.form.success'),
  class: className,
} = Astro.props;
const intentOptions = [
  {
    id: 'showcase-site-498',
    key: 'contact.form.intent.option.showcase',
  },
  {
    id: 'delivery-site-998',
    key: 'contact.form.intent.option.delivery',
  },
  {
    id: 'other',
    key: 'contact.form.intent.option.other',
  },
];
---

<form
  id="contact-form"
  action={action}
  method="POST"
  class={cn('space-y-6', className)}
  data-success-message={successMessage}
>
  <!-- Name + Email side by side on sm+ -->
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
    <Input
      label={t('contact.form.name')}
      labelKey="contact.form.name"
      name="name"
      type="text"
      required
      autocomplete="name"
    />
    <Input
      label={t('contact.form.email')}
      labelKey="contact.form.email"
      name="email"
      type="email"
      required
      autocomplete="email"
    />
  </div>

  <div class="space-y-1.5">
    <label for="contact-intent" class="text-sm font-medium leading-none">
      <span data-i18n="contact.form.intent">{t('contact.form.intent')}</span>
    </label>
    <div class="relative">
      <select
        id="contact-intent"
        name="subject"
        class="flex h-11 w-full appearance-none rounded-xl border border-border bg-background px-4 py-2 pr-10 text-sm text-foreground transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:cursor-not-allowed disabled:opacity-50"
        required
      >
        <option value="" disabled selected data-i18n="contact.form.intent.placeholder">
          {t('contact.form.intent.placeholder')}
        </option>
        {intentOptions.map((option) => (
          <option value={t(option.key)} data-i18n={option.key} data-intent-id={option.id}>
            {t(option.key)}
          </option>
        ))}
      </select>
      <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center pr-3">
        <svg
          class="h-4 w-4 text-muted-foreground"
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 20 20"
          fill="currentColor"
          aria-hidden="true"
        >
          <path
            fill-rule="evenodd"
            d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z"
            clip-rule="evenodd"
          />
        </svg>
      </div>
    </div>
  </div>

  <Textarea
    label={t('contact.form.message')}
    labelKey="contact.form.message"
    name="message"
    required
    rows={5}
  />

  <!-- Honeypot field for spam protection -->
  <div class="hidden" aria-hidden="true">
    <input type="text" name="honeypot" tabindex="-1" autocomplete="off" />
  </div>

  <div id="form-message" class="hidden text-sm"></div>

  <div class="flex justify-center">
    <Button type="submit" id="submit-button" class="gap-2">
      <span data-i18n="contact.form.submit">{t('contact.form.submit')}</span>
      <Icon name="arrow-right" size="sm" />
    </Button>
  </div>
</form>

<script>
  import { translations } from '@/config/i18n.config';

  function initContactForm() {
    const form = document.getElementById('contact-form') as HTMLFormElement;
    const button = document.getElementById('submit-button') as HTMLButtonElement;
    const message = document.getElementById('form-message') as HTMLDivElement;
    const intentSelect = document.getElementById('contact-intent') as HTMLSelectElement | null;

    if (!form || !button || !message) return;

    const getLang = () => {
      const stored = localStorage.getItem('site_lang');
      if (stored === 'zh' || stored === 'en') return stored;
      return (navigator.language || '').toLowerCase().startsWith('zh') ? 'zh' : 'en';
    };

    const getText = (key: string) => {
      const lang = getLang();
      return translations[lang]?.[key] || translations.en[key] || key;
    };

    const setSubmitLabel = (key: string) => {
      const label = button.querySelector('[data-i18n]') as HTMLElement | null;
      if (label) label.textContent = getText(key);
    };

    const syncIntentOptions = () => {
      if (!intentSelect) return;

      intentSelect.querySelectorAll<HTMLOptionElement>('option[data-i18n]').forEach((option) => {
        const key = option.dataset.i18n;
        if (!key || option.value === '') return;
        option.value = getText(key);
      });
    };

    const successMessage = form.dataset.successMessage || getText('contact.form.success');
    syncIntentOptions();

    if (form.dataset.contactInit === 'true') return;
    form.dataset.contactInit = 'true';

    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      button.disabled = true;
      setSubmitLabel('contact.form.sending');
      message.classList.add('hidden');

      try {
        const formData = new FormData(form);
        const response = await fetch(form.action, {
          method: 'POST',
          body: formData,
        });

        const data = await response.json();

        if (data.success) {
          message.textContent = successMessage;
          message.className = 'text-sm text-success';
          form.reset();
        } else {
          const errors = data.errors
            ? Object.values(data.errors).flat().join(', ')
            : getText('contact.form.error.generic');
          message.textContent = errors as string;
          message.className = 'text-sm text-destructive';
        }
      } catch {
        message.textContent = getText('contact.form.error.failed');
        message.className = 'text-sm text-destructive';
      } finally {
        button.disabled = false;
        setSubmitLabel('contact.form.submit');
        message.classList.remove('hidden');
      }
    });
  }

  initContactForm();
  document.addEventListener('astro:after-swap', initContactForm);
  document.addEventListener('astro:page-load', initContactForm);
  document.addEventListener('site:lang-change', initContactForm);
</script>
