      'cta.subtitle': '停止向外卖平台缴纳30%佣金。让我们为您打造数字帝国——从品牌网站到点餐系统到广告投放。',
      'cta.button': '联系我们',
      'cta.button2': '了解更多',
    },
  };

  // ── Navigation label keys for dynamic nav translation ──
  const navLabelMap: Record<string, string> = {
    'Blog': 'blog.badge',
    'Projects': 'portfolio.badge',
    'About': 'nav.about',
    'Contact': 'nav.contact',
    'Services': 'nav.services',
    'Portfolio': 'nav.portfolio',
    // ZH reverse-map
    '服务': 'nav.services',
    '案例展示': 'nav.portfolio',
    '关于我们': 'nav.about',
    '联系我们': 'nav.contact',
    '行业资讯': 'blog.badge',
  };

  function detectLang(): string {
    // 1. Check explicit user selection
    const stored = localStorage.getItem('site_lang');
    if (stored === 'zh' || stored === 'en') return stored;

    // 2. Auto-detect browser language
    const browserLang = (navigator.language || '').toLowerCase();
    return browserLang.startsWith('zh') ? 'zh' : 'en';
  }

  function applyTranslations(lang: string) {
    const dict = translations[lang] || translations.en;
    if (!dict) return;

    // Inject text into all data-i18n elements
    document.querySelectorAll<HTMLElement>('[data-i18n]').forEach((el) => {
      const key = el.getAttribute('data-i18n');
      if (key && dict[key]) {
        el.textContent = dict[key];
      }
    });

    // Translate navigation links in header & footer & mobile
    document.querySelectorAll<HTMLElement>('nav a, footer a').forEach((link) => {
      const text = link.textContent?.trim() ?? '';
      const mapKey = navLabelMap[text];
      if (mapKey && dict[mapKey]) {
        link.textContent = dict[mapKey];
      }
    });

    // Update active button visual
    document.querySelectorAll<HTMLElement>('[data-lang-btn]').forEach((btn) => {
      const btnLang = btn.getAttribute('data-lang-btn');
      if (btnLang === lang) {
        btn.classList.add('text-foreground', 'font-bold');
        btn.classList.remove('text-foreground-muted');
      } else {
        btn.classList.remove('text-foreground', 'font-bold');
        btn.classList.add('text-foreground-muted');
      }
    });

    // Set html lang attribute
    document.documentElement.lang = lang === 'zh' ? 'zh-CN' : 'en';
  }

  function initLanguageSwitcher() {
    const lang = detectLang();
    applyTranslations(lang);

    // On first visit with auto-detection, save the choice
    if (!localStorage.getItem('site_lang')) {
      localStorage.setItem('site_lang', lang);
    }

    // Bind click handlers
    document.querySelectorAll<HTMLElement>('[data-lang-btn]').forEach((btn) => {
      // Avoid duplicate listeners
      if (btn.dataset.langInit) return;
      btn.dataset.langInit = 'true';

      btn.addEventListener('click', () => {
        const targetLang = btn.getAttribute('data-lang-btn') ?? 'en';
        localStorage.setItem('site_lang', targetLang);
        applyTranslations(targetLang);
      });
    });
  }

  // ── Run ──
  initLanguageSwitcher();
  document.addEventListener('astro:after-swap', initLanguageSwitcher);
  document.addEventListener('astro:page-load', initLanguageSwitcher);
</script>
