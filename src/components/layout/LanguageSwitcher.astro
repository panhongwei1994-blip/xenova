---
/**
 * LanguageSwitcher Component
 *
 * Dual-mode language switcher: auto-detects browser language on first visit,
 * then allows manual toggle between EN and ZH. Injects translations from
 * the centralized i18n.config.ts via data-i18n attributes.
 */
import { cn } from '@/lib/cn';

interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<div class={cn("flex items-center text-sm font-medium", className)} id="lang-switcher">
  <button
    type="button"
    data-lang-btn="zh"
    class="lang-switch-btn inline-flex items-center justify-center rounded-md px-2 py-1.5 text-foreground-muted hover:text-foreground hover:bg-secondary transition-colors cursor-pointer"
    title="切换到中文"
  >
    中
  </button>
  <span class="text-border/50 text-xs mx-0.5">/</span>
  <button
    type="button"
    data-lang-btn="en"
    class="lang-switch-btn inline-flex items-center justify-center rounded-md px-2 py-1.5 text-foreground-muted hover:text-foreground hover:bg-secondary transition-colors cursor-pointer"
    title="Switch to English"
  >
    EN
  </button>
</div>

<script>
