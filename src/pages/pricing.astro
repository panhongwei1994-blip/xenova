---
import PageLayout from '@/layouts/PageLayout.astro';
import { Hero } from '@/components/hero';
import Badge from '@/components/ui/data-display/Badge/Badge.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import PricingCards from '@/components/landing/PricingCards.astro';
import { t } from '@/config/i18n.config';

const trustKeys = ['pricing.trust.1', 'pricing.trust.2', 'pricing.trust.3', 'pricing.trust.4'];
---

<PageLayout
  title="Pricing — Hi Sora"
  description="Simple one-time pricing for restaurant showcase sites and delivery ordering systems."
>
  <Hero layout="centered" size="sm">
    <Badge slot="badge" variant="brand" pill>
      <Icon name="badge-dollar-sign" size="sm" />
      <span data-i18n="nav.pricing">{t('nav.pricing')}</span>
    </Badge>

    <h1 slot="title" class="text-balance">
      <span data-i18n="pricing.page.title.lead">{t('pricing.page.title.lead')}</span>{' '}
      <span class="text-brand-500" data-i18n="pricing.page.title.highlight">{t('pricing.page.title.highlight')}</span>
    </h1>

    <p slot="description" class="text-pretty">
      <span data-i18n="pricing.page.subtitle">{t('pricing.page.subtitle')}</span>
    </p>
  </Hero>

  <section class="border-t border-border bg-background-secondary py-[var(--space-section-sm)]">
    <div class="mx-auto flex max-w-5xl flex-wrap items-center justify-center gap-3 px-6">
      {trustKeys.map((key) => (
        <Badge variant="brand" pill class="bg-background text-foreground shadow-sm">
          <span data-i18n={key}>{t(key)}</span>
        </Badge>
      ))}
    </div>
  </section>

  <section class="border-t border-border bg-background py-[var(--space-section-md)]">
    <div class="mx-auto max-w-6xl px-6">
      <PricingCards />
    </div>
  </section>
</PageLayout>
