---
import LandingLayout from '@/layouts/LandingLayout.astro';
import { Hero } from '@/components/hero';
import Button from '@/components/ui/form/Button/Button.astro';
import Badge from '@/components/ui/data-display/Badge/Badge.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import BlogCard from '@/components/blog/BlogCard.astro';
import { getCollection } from 'astro:content';
import { t } from '@/config/i18n.config';
import { Image } from 'astro:assets';
import RoiCalculator from '@/components/landing/RoiCalculator.astro';
import PricingCards from '@/components/landing/PricingCards.astro';
import ramenImage from '@/assets/images/projects/ramen.jpg';
import sushiImage from '@/assets/images/projects/sushi.jpg';
import bistroImage from '@/assets/images/projects/bistro.png';

const projectItems = await getCollection('projects');
const featuredProjects = projectItems
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 3);

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => {
    if (a.data.featured !== b.data.featured) return a.data.featured ? -1 : 1;
    return b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf();
  })
  .slice(0, 3);

const pricingTrustKeys = ['pricing.trust.1', 'pricing.trust.2', 'pricing.trust.3', 'pricing.trust.4'];
const visualMoments = [
  {
    image: ramenImage,
    alt: 'Restaurant menu and ordering preview',
    labelKey: 'visual.moment.menu',
  },
  {
    image: sushiImage,
    alt: 'Restaurant brand website preview',
    labelKey: 'visual.moment.brand',
  },
  {
    image: bistroImage,
    alt: 'Restaurant direct ordering experience preview',
    labelKey: 'visual.moment.order',
  },
];
---

<LandingLayout
  title="Hi Sora — Restaurant Digital Agency"
  description="Hi Sora — We build independent ordering systems and high-converting websites for restaurants."
  image="/og-default.svg"
  includePersonSchema={true}
  includeProfessionalServiceSchema={true}
>
  <!-- Hero -->
  <Hero layout="centered" size="xl" class="hero-dark-gradient !pt-28 md:!pt-[calc(var(--space-page-top)_+_var(--space-16))]" showScrollIndicator descriptionClass="max-w-3xl">
    <Badge slot="badge" variant="brand" pill pulse class="dark:text-brand-200">
      <span data-i18n="hero.badge">{t('hero.badge')}</span>
    </Badge>

    <h1 slot="title">
      <span class="text-foreground [-webkit-text-fill-color:currentColor]" data-i18n="hero.headline">{t('hero.headline')}</span><br />
      <span class="text-brand-500 [-webkit-text-fill-color:var(--color-brand-500)] dark:text-foreground dark:[-webkit-text-fill-color:currentColor]" data-i18n="hero.headline2">{t('hero.headline2')}</span>
    </h1>

    <p slot="description" data-i18n="hero.subheadline">
      {t('hero.subheadline')}
    </p>

   <Fragment slot="actions">
      <Button size="lg" href="#roi-calculator">
        <span data-i18n="hero.cta">{t('hero.cta')}</span>
        <Icon name="calculator" size="sm" />
      </Button>
      <Button size="lg" variant="outline" href="#work">
        <Icon name="layers" size="sm" />
        <span data-i18n="hero.cta2">{t('hero.cta2')}</span>
        <Icon name="arrow-right" size="sm" />
      </Button>
    </Fragment>

    <div class="mt-6 flex flex-wrap items-center justify-center gap-3 text-center text-sm text-foreground-muted" data-reveal data-reveal-delay="1">
      {['hero.trust.1', 'hero.trust.2', 'hero.trust.3'].map((key) => (
        <span class="inline-flex items-center gap-2 rounded-full border border-border bg-background/70 px-4 py-2 shadow-sm">
          <Icon name="badge-check" size="xs" class="text-brand-500" />
          <span data-i18n={key}>{t(key)}</span>
        </span>
      ))}
    </div>
  </Hero>

  <!-- ROI Calculator -->
  <section
    id="roi-calculator"
    class="relative z-10 scroll-mt-24 border-t border-border bg-background-secondary py-[var(--space-section-md)] md:scroll-mt-28"
  >
    <div class="mx-auto flex max-w-6xl flex-col gap-8 px-6">
      <div class="flex flex-col items-center gap-4 text-center" data-reveal>
        <div class="flex flex-col items-center gap-6">
          <Badge variant="brand" pill><span data-i18n="roi.title">{t('roi.title')}</span></Badge>
          <h2 class="font-display text-3xl font-bold text-foreground md:text-4xl">
            <span data-i18n="roi.section.title">{t('roi.section.title')}</span>
          </h2>
        </div>
        <p class="max-w-3xl text-lg text-foreground-muted text-pretty" data-i18n="roi.section.subtitle">
          {t('roi.section.subtitle')}
        </p>
      </div>

      <Card
        variant="elevated"
        padding="lg"
        class="mx-auto w-full max-w-4xl border border-border/80 bg-background dark:border-white/10 dark:bg-white/[0.03] dark:shadow-[0_24px_80px_-48px_rgba(255,255,255,0.18)]"
        data-reveal
        data-reveal-delay="1"
      >
        <RoiCalculator />
      </Card>
    </div>
  </section>

  <!-- Visual Proof -->
  <section class="relative z-10 border-t border-border bg-background py-[var(--space-section-md)]">
    <div class="mx-auto grid max-w-6xl gap-10 px-6 lg:grid-cols-[0.9fr_1.1fr] lg:items-center">
      <div class="flex flex-col gap-5" data-reveal>
        <Badge variant="brand" pill class="self-start">
          <span data-i18n="visual.badge">{t('visual.badge')}</span>
        </Badge>
        <h2 class="font-display text-3xl font-bold text-foreground md:text-4xl" data-i18n="visual.title">
          {t('visual.title')}
        </h2>
        <p class="max-w-xl text-lg leading-relaxed text-foreground-muted" data-i18n="visual.subtitle">
          {t('visual.subtitle')}
        </p>
      </div>

      <div class="grid gap-4 sm:grid-cols-3" data-reveal data-reveal-delay="1">
        {visualMoments.map((moment, index) => (
          <figure class={`group overflow-hidden rounded-2xl border border-border bg-background-secondary shadow-sm ${index === 0 ? 'sm:col-span-2' : ''}`}>
            <div class={index === 0 ? 'aspect-[4/3]' : 'aspect-[3/4]'}>
              <Image
                src={moment.image}
                alt={moment.alt}
                class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
              />
            </div>
            <figcaption class="border-t border-border px-4 py-3 text-sm font-semibold text-foreground">
              <span data-i18n={moment.labelKey}>{t(moment.labelKey)}</span>
            </figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <!-- Portfolio -->
  <section id="work" class="relative z-10 py-[var(--space-section-md)] bg-background-secondary border-t border-border">
    <div class="mx-auto max-w-6xl px-6 flex flex-col gap-8">
      <div class="flex flex-col items-center gap-4 text-center" data-reveal>
        <div class="flex flex-col items-center gap-6">
          <Badge variant="brand" pill><span data-i18n="portfolio.badge">{t('portfolio.badge')}</span></Badge>
          <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground" data-i18n="portfolio.title">
            {t('portfolio.title')}
          </h2>
        </div>
        <p class="text-lg text-foreground-muted max-w-2xl mx-auto" data-i18n="portfolio.subtitle">
          {t('portfolio.subtitle')}
        </p>
      </div>

      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3" data-reveal data-reveal-delay="1">
        {featuredProjects.map((project) => (
          <Card 
            variant="elevated" 
            hover 
            padding="lg" 
            href={project.data.url || `/projects/${project.id.replace(/\.mdx?$/, '')}`} 
            target="_blank" 
            rel="noopener noreferrer" 
            class="group flex flex-col"
          >
            <div class="flex flex-1 flex-col">
              {project.data.image ? (
                <div class="mb-4 h-56 lg:h-48 w-full overflow-hidden rounded-lg">
                  <Image src={project.data.image} alt={project.data.title} class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105" />
                </div>
              ) : (
                <div class="mb-4 h-56 lg:h-48 w-full overflow-hidden rounded-lg bg-background-tertiary flex items-center justify-center">
                  <Icon name="layers" class="w-12 h-12 text-brand-500/40" />
                </div>
              )}
              <div class="flex items-center gap-2 mb-2">
                {project.data.icon && (
                  <Icon name={project.data.icon} class="w-5 h-5 text-brand-500 shrink-0" />
                )}
                <h3 class="font-display text-lg font-bold text-foreground truncate" data-i18n={`portfolio.${project.id.replace(/\\.mdx?$/, '')}.title`}>{t(`portfolio.${project.id.replace(/\\.mdx?$/, '')}.title`) || project.data.title}</h3>
                <Icon name="arrow-up-right" size="sm" class="ml-auto text-foreground-muted group-hover:text-brand-500 transition-colors shrink-0" />
              </div>
              <p class="text-sm text-foreground-muted leading-relaxed line-clamp-3 md:line-clamp-2 mt-1 flex-1" data-i18n={`portfolio.${project.id.replace(/\\.mdx?$/, '')}.description`}>{t(`portfolio.${project.id.replace(/\\.mdx?$/, '')}.description`) || project.data.description}</p>
            </div>
          </Card>
        ))}
      </div>
    </div>
  </section>

  <!-- Pricing -->
  <section
    id="pricing"
    class="relative z-10 scroll-mt-24 border-t border-border bg-background-secondary py-[var(--space-section-md)] md:scroll-mt-28"
  >
    <div class="mx-auto flex max-w-6xl flex-col gap-8 px-6">
      <div class="flex flex-col items-center gap-4 text-center" data-reveal>
        <div class="flex flex-col items-center gap-6">
          <Badge variant="brand" pill><span data-i18n="nav.pricing">{t('nav.pricing')}</span></Badge>
          <h2 class="font-display text-3xl font-bold text-foreground md:text-4xl">
            <span data-i18n="pricing.page.title.lead">{t('pricing.page.title.lead')}</span>{' '}
            <span class="text-brand-500" data-i18n="pricing.page.title.highlight">{t('pricing.page.title.highlight')}</span>
          </h2>
        </div>
        <p class="max-w-3xl text-lg text-foreground-muted text-pretty" data-i18n="pricing.page.subtitle">
          {t('pricing.page.subtitle')}
        </p>
      </div>

      <div class="flex flex-wrap items-center justify-center gap-3" data-reveal data-reveal-delay="1">
        {pricingTrustKeys.map((key) => (
          <Badge variant="brand" pill class="bg-background text-foreground shadow-sm">
            <span data-i18n={key}>{t(key)}</span>
          </Badge>
        ))}
      </div>

      <PricingCards />
    </div>
  </section>

  <!-- Services Section -->
  <section id="services" class="relative z-10 py-[var(--space-section-md)] bg-background border-t border-border">
    <div class="mx-auto max-w-6xl px-6 flex flex-col gap-8">
      <div class="flex flex-col items-center gap-4 text-center" data-reveal>
        <div class="flex flex-col items-center gap-6">
          <Badge variant="brand" pill><span data-i18n="services.badge">{t('services.badge')}</span></Badge>
          <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground" data-i18n="services.title">
            {t('services.title')}
          </h2>
        </div>
        <p class="text-lg text-foreground-muted max-w-2xl mx-auto" data-i18n="services.subtitle">
          {t('services.subtitle')}
        </p>
      </div>

      <div class="grid gap-6 md:grid-cols-3" data-reveal data-reveal-delay="1">
        <!-- Branded Delivery System -->
        <Card hover>
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
              <Icon name="shopping-cart" size="sm" />
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="text-base font-semibold text-foreground" data-i18n="services.2.title">{t('services.2.title')}</h3>
              <p class="text-sm text-foreground-muted leading-relaxed mt-1.5" data-i18n="services.2.desc">
                {t('services.2.desc')}
              </p>
            </div>
          </div>
        </Card>

        <!-- Mobile-First Website -->
        <Card hover>
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
              <Icon name="smartphone" size="sm" />
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="text-base font-semibold text-foreground" data-i18n="services.1.title">{t('services.1.title')}</h3>
              <p class="text-sm text-foreground-muted leading-relaxed mt-1.5" data-i18n="services.1.desc">
                {t('services.1.desc')}
              </p>
            </div>
          </div>
        </Card>

        <!-- Google & FB Traffic -->
        <Card hover>
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
              <Icon name="megaphone" size="sm" />
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="text-base font-semibold text-foreground" data-i18n="services.3.title">{t('services.3.title')}</h3>
              <p class="text-sm text-foreground-muted leading-relaxed mt-1.5" data-i18n="services.3.desc">
                {t('services.3.desc')}
              </p>
            </div>
          </div>
        </Card>
      </div>
    </div>
  </section>

  <!-- About Teaser -->
  <section class="relative z-10 py-[var(--space-section-md)] bg-background border-t border-border">
    <div class="mx-auto max-w-6xl px-6">
      <div class="grid gap-12 lg:grid-cols-2">
        <div class="flex flex-col justify-center" data-reveal>
          <div class="flex flex-col gap-6 mb-6">
            <Badge variant="brand" pill class="self-start"><span data-i18n="about.badge">{t('about.badge')}</span></Badge>
            <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground">
              <span data-i18n="about.title">{t('about.title')}</span><br />
              <span class="text-brand-500" data-i18n="about.title.highlight">{t('about.title.highlight')}</span>
            </h2>
          </div>
          <p class="text-lg text-foreground-muted leading-relaxed mb-4" data-i18n="about.p1">
           {t('about.p1')}
          </p>
          <p class="text-lg text-foreground-muted leading-relaxed mb-8" data-i18n="about.p2">
           {t('about.p2')}
          </p>
           <Button variant="outline" href="/about" class="self-start">
            <span data-i18n="about.cta">{t('about.cta')}</span>
          </Button>
        </div>
        <Card variant="elevated" padding="lg" class="h-full flex flex-col" data-reveal data-reveal-delay="1">
          <p class="text-sm text-foreground mb-5 text-center" data-i18n="about.badge">{t('about.badge')}</p>
          <div class="grid grid-cols-2 gap-3 flex-1 auto-rows-fr">
            <div class="bg-background-tertiary rounded-xl p-5 flex flex-col items-center justify-center text-center gap-2 border-t-2 border-brand-500/40 transition-all duration-200 hover:-translate-y-1 hover:shadow-md hover:border-brand-500 cursor-default h-full">
              <Icon name="utensils" class="w-10 h-10 text-brand-500" />
              <p class="text-sm font-semibold text-foreground" data-i18n="about.stat1">{t('about.stat1')}</p>
            </div>
            <div class="bg-background-tertiary rounded-xl p-5 flex flex-col items-center justify-center text-center gap-2 border-t-2 border-brand-500/40 transition-all duration-200 hover:-translate-y-1 hover:shadow-md hover:border-brand-500 cursor-default h-full">
              <Icon name="chef-hat" class="w-10 h-10 text-brand-500" />
              <p class="text-sm font-semibold text-foreground" data-i18n="about.stat2">{t('about.stat2')}</p>
            </div>
            <div class="bg-background-tertiary rounded-xl p-5 flex flex-col items-center justify-center text-center gap-2 border-t-2 border-brand-500/40 transition-all duration-200 hover:-translate-y-1 hover:shadow-md hover:border-brand-500 cursor-default h-full">
              <Icon name="globe" class="w-10 h-10 text-brand-500" />
              <p class="text-sm font-semibold text-foreground" data-i18n="about.stat3">{t('about.stat3')}</p>
            </div>
            <div class="bg-background-tertiary rounded-xl p-5 flex flex-col items-center justify-center text-center gap-2 border-t-2 border-brand-500/40 transition-all duration-200 hover:-translate-y-1 hover:shadow-md hover:border-brand-500 cursor-default h-full">
              <Icon name="map-pin" class="w-10 h-10 text-brand-500" />
              <p class="text-sm font-semibold text-foreground" data-i18n="about.stat4">{t('about.stat4')}</p>
            </div>
          </div>
        </Card>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="relative z-10 py-[var(--space-section-md)] bg-background border-t border-border">
    <div class="mx-auto max-w-6xl px-6 flex flex-col gap-8">
      <div class="flex flex-col items-center gap-4 text-center" data-reveal>
        <div class="flex flex-col items-center gap-6">
          <Badge variant="brand" pill><span data-i18n="testimonials.badge">{t('testimonials.badge')}</span></Badge>
          <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground" data-i18n="testimonials.title">
            {t('testimonials.title')}
          </h2>
        </div>
        <p class="text-lg text-foreground-muted" data-i18n="testimonials.subtitle">
          {t('testimonials.subtitle')}
        </p>
      </div>

      <div class="grid gap-6 md:grid-cols-2" data-reveal data-reveal-delay="1">
        <!-- Testimonial 1 -->
        <Card variant="elevated" padding="lg" hover>
          <div class="flex flex-col h-full gap-4">
            <div class="flex gap-1 text-brand-500" role="img" aria-label="5 out of 5 stars">
              {[...Array(5)].map(() => (
                <svg class="w-4 h-4 fill-current" viewBox="0 0 20 20" aria-hidden="true">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>
            <blockquote class="flex-1 text-foreground-muted leading-relaxed" data-i18n="testimonials.1.quote">
              {t('testimonials.1.quote')}
            </blockquote>
            <div class="flex items-center gap-3 pt-4 border-t border-border">
              <div class="w-9 h-9 rounded-full bg-gradient-to-br from-brand-500/30 to-brand-500/10 flex items-center justify-center text-brand-500 font-bold text-sm shrink-0">
                D
              </div>
              <div>
                <p class="text-sm font-semibold text-foreground" data-i18n="testimonials.1.name">{t('testimonials.1.name')}</p>
                <p class="text-xs text-foreground-muted" data-i18n="testimonials.1.role">{t('testimonials.1.role')}</p>
              </div>
            </div>
          </div>
        </Card>

        <!-- Testimonial 2 -->
        <Card variant="elevated" padding="lg" hover>
          <div class="flex flex-col h-full gap-4">
            <div class="flex gap-1 text-brand-500" role="img" aria-label="5 out of 5 stars">
              {[...Array(5)].map(() => (
                <svg class="w-4 h-4 fill-current" viewBox="0 0 20 20" aria-hidden="true">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>
            <blockquote class="flex-1 text-foreground-muted leading-relaxed" data-i18n="testimonials.2.quote">
              {t('testimonials.2.quote')}
            </blockquote>
            <div class="flex items-center gap-3 pt-4 border-t border-border">
              <div class="w-9 h-9 rounded-full bg-gradient-to-br from-brand-500/30 to-brand-500/10 flex items-center justify-center text-brand-500 font-bold text-sm shrink-0">
                M
              </div>
              <div>
                <p class="text-sm font-semibold text-foreground" data-i18n="testimonials.2.name">{t('testimonials.2.name')}</p>
                <p class="text-xs text-foreground-muted" data-i18n="testimonials.2.role">{t('testimonials.2.role')}</p>
              </div>
            </div>
          </div>
        </Card>
      </div>
    </div>
  </section>

  <!-- Blog -->
  <section class="relative z-10 py-[var(--space-section-md)] bg-background-secondary border-t border-border">
    <div class="mx-auto max-w-6xl px-6 flex flex-col gap-8">
      <div class="flex items-end justify-between" data-reveal>
        <div class="flex flex-col gap-6">
          <Badge variant="brand" pill class="self-start"><span data-i18n="blog.badge">{t('blog.badge')}</span></Badge>
          <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground" data-i18n="blog.title">
            {t('blog.title')}
          </h2>
        </div>
        <a href="/blog" class="hidden sm:inline-flex items-center gap-1.5 text-sm font-medium text-brand-500 hover:text-brand-600 transition-colors shrink-0">
          <span data-i18n="blog.viewall">{t('blog.viewall')}</span>
          <Icon name="arrow-right" size="sm" />
        </a>
      </div>

      <div class="grid gap-6 md:grid-cols-3" data-reveal data-reveal-delay="1">
        {posts.map((post) => (
          <BlogCard
            title={post.data.title}
            description={post.data.description}
            href={`/blog/${post.id.replace('en/', '')}`}
            publishedAt={post.data.publishedAt}
            tags={post.data.tags}
            author={post.data.author}
