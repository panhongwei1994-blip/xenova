---
/**
 * Contact page
 * URL: /contact
 */
import PageLayout from '@/layouts/PageLayout.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import Badge from '@/components/ui/data-display/Badge/Badge.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
import { Hero } from '@/components/hero';
import ContactForm from '@/components/patterns/ContactForm.astro';
import siteConfig from '@/config/site.config';
import { resolveSocialLinks } from '@/lib/utils';
import { t } from '@/config/i18n.config';

const socialLinks = resolveSocialLinks(siteConfig.socialLinks);

const channels = [
  {
    icon: 'mail',
    label: t('contact.channel.email'),
    value: siteConfig.email,
    href: `mailto:${siteConfig.email}`,
    external: false,
  },
  ...socialLinks.map((link) => ({
    icon: link.icon,
    label: link.label,
    value: link.href.replace(/^https?:\/\/(www\.)?/, ''),
    href: link.href,
    external: true,
  })),
];
---

<PageLayout
  title={t('contact.meta.title')}
  description={t('contact.meta.description')}
  eagerReveal
>
  <Hero layout="centered" size="sm" class="pt-6 pb-2 md:pt-[var(--space-page-top-sm)] md:pb-[var(--space-section-sm)]">
    <Badge slot="badge" variant="brand" pill class="mb-2 md:mb-[var(--space-heading-gap)]">
      <Icon name="mail" size="sm" />
      <span data-i18n="contact.hero.badge">{t('contact.hero.badge')}</span>
    </Badge>

    <h1 slot="title" class="hidden md:block md:mb-[var(--space-heading-gap)]">
      <span data-i18n="contact.hero.title.lead">{t('contact.hero.title.lead')}</span>{' '}
      <span class="text-brand-500" data-i18n="contact.hero.title.highlight">{t('contact.hero.title.highlight')}</span>
    </h1>

    <p slot="description" class="hidden md:block" data-i18n="contact.hero.description">
      {t('contact.hero.description')}
    </p>
  </Hero>

  <!-- Contact Section -->
  <section class="py-[var(--space-section-md)] bg-background-secondary border-t border-border">
    <div class="mx-auto max-w-5xl px-6">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-10 lg:gap-16 items-stretch">

        <!-- Left column: contact form -->
        <div class="lg:col-span-3 h-full" data-reveal>
          <Card padding="lg" class="h-full flex flex-col justify-center">
            <h2 class="font-display text-xl font-bold text-foreground mb-6" data-i18n="contact.form.title">
              {t('contact.form.title')}
            </h2>
            <ContactForm />
          </Card>
        </div>

        <!-- Right column: contact channels -->
        <div class="lg:col-span-2 space-y-4" data-reveal data-reveal-delay="1">
          <div>
            <h2 class="font-display text-lg font-bold text-foreground mb-1" data-i18n="contact.channels.title">
              {t('contact.channels.title')}
            </h2>
            <p class="text-sm text-foreground-muted" data-i18n="contact.channels.subtitle">
              {t('contact.channels.subtitle')}
            </p>
          </div>

          <Card padding="sm" class="border-brand-500/20 bg-brand-500/5">
            <div class="space-y-4">
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 shrink-0 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500">
                  <Icon name="message-circle" size="sm" />
                </div>
                <div>
                  <p class="font-semibold text-sm text-foreground" data-i18n="contact.channel.wechat">
                    {t('contact.channel.wechat')}
                  </p>
                  <p class="text-xs text-foreground-muted" data-i18n="contact.channel.wechat.desc">
                    {t('contact.channel.wechat.desc')}
                  </p>
                </div>
              </div>

              <img
                src="/contact/wechat-qr.jpeg"
                alt="WeChat QR code"
                class="w-full rounded-2xl border border-border bg-background"
                loading="lazy"
              />

              <div class="rounded-xl border border-border bg-background px-4 py-3 text-center">
                <p class="text-xs uppercase tracking-[0.14em] text-foreground-muted" data-i18n="contact.channel.wechat.id_label">
                  {t('contact.channel.wechat.id_label')}
                </p>
                <p class="mt-1 font-semibold text-foreground" translate="no">hisoracc</p>
              </div>
            </div>
          </Card>

          <!-- Channel list -->
          <div class="space-y-2">
            {channels.map((ch) => (
              <a
                href={ch.href}
                {...ch.external ? { target: '_blank', rel: 'noopener noreferrer' } : {}}
                class="block group"
              >
                <Card hover padding="sm" class="h-full">
                  <div class="flex items-center gap-3">
                    <div class="w-10 h-10 shrink-0 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500">
                      <Icon name={ch.icon} size="sm" />
                    </div>
                    <div class="min-w-0 flex-1">
                      <p class="font-semibold text-sm text-foreground">{ch.label}</p>
                      <p class="text-xs text-foreground-muted truncate">{ch.value}</p>
                    </div>
                    <Icon name="arrow-up-right" size="sm" class="text-foreground-muted group-hover:text-brand-500 transition-colors shrink-0" />
                  </div>
                </Card>
              </a>
            ))}
          </div>

          <!-- Location card -->
          <Card hover padding="sm" class="bg-brand-500/5 border-brand-500/20">
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 shrink-0 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500">
                <Icon name="map-pin" size="sm" />
              </div>
              <div>
                <p class="font-semibold text-sm text-foreground">{siteConfig.address?.city ?? 'Your City'}</p>
                <p class="text-xs text-foreground-muted mt-0.5">
                  <span data-i18n="contact.location.basedIn">{t('contact.location.basedIn')}</span>{' '}
                  {siteConfig.address?.country ?? 'Your Country'}
                </p>
              </div>
            </div>
          </Card>

        </div>

      </div>
    </div>
  </section>
</PageLayout>
