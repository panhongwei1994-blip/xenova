---
/**
 * Contact page
 * URL: /contact
 */
import PageLayout from '@/layouts/PageLayout.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import Badge from '@/components/ui/data-display/Badge/Badge.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
import { Hero } from '@/components/hero';
import ContactForm from '@/components/patterns/ContactForm.astro';
import siteConfig from '@/config/site.config';
import { t } from '@/config/i18n.config';

const whatsappPhone = siteConfig.phone?.replace(/[^\d]/g, '') ?? '';
const whatsappHref = whatsappPhone ? `https://wa.me/${whatsappPhone}` : null;
---

<PageLayout
  title={t('contact.meta.title')}
  description={t('contact.meta.description')}
  eagerReveal
>
  <Hero layout="centered" size="sm" class="pt-6 pb-2 md:pt-[var(--space-page-top-sm)] md:pb-[var(--space-section-sm)]">
    <Badge slot="badge" variant="brand" pill class="mb-2 md:mb-[var(--space-heading-gap)]">
      <Icon name="mail" size="sm" />
      <span data-i18n="contact.hero.badge">{t('contact.hero.badge')}</span>
    </Badge>

    <h1 slot="title" class="hidden md:block md:mb-[var(--space-heading-gap)]">
      <span data-i18n="contact.hero.title.lead">{t('contact.hero.title.lead')}</span>{' '}
      <span class="text-brand-500" data-i18n="contact.hero.title.highlight">{t('contact.hero.title.highlight')}</span>
    </h1>

    <p slot="description" class="hidden md:block" data-i18n="contact.hero.description">
      {t('contact.hero.description')}
    </p>
  </Hero>

  <!-- Contact Section -->
  <section class="py-[var(--space-section-md)] bg-background-secondary border-t border-border">
    <div class="mx-auto max-w-6xl px-6">
      <div class="grid grid-cols-1 gap-8 xl:grid-cols-[1.05fr_0.95fr]">
        <div class="space-y-6" data-reveal>
          <div class="space-y-2">
            <h2 class="font-display text-2xl font-bold text-foreground" data-i18n="contact.direct.title">
              {t('contact.direct.title')}
            </h2>
            <p class="text-sm text-foreground-muted" data-i18n="contact.direct.subtitle">
              {t('contact.direct.subtitle')}
            </p>
          </div>

          <Card padding="lg" class="border-brand-500/20 bg-brand-500/5">
            <div class="grid gap-6 md:grid-cols-[0.95fr_1.05fr] md:items-start">
              <div class="space-y-4">
                <div class="flex items-center gap-3">
                  <div class="w-11 h-11 shrink-0 rounded-2xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500">
                    <Icon name="message-circle" size="sm" />
                  </div>
                  <div>
                    <p class="font-semibold text-base text-foreground" data-i18n="contact.channel.wechat">
                      {t('contact.channel.wechat')}
                    </p>
                    <p class="text-xs text-foreground-muted" data-i18n="contact.channel.wechat.desc">
                      {t('contact.channel.wechat.desc')}
                    </p>
                  </div>
                </div>

                <div class="rounded-2xl border border-border bg-background px-4 py-3">
                  <p class="text-xs uppercase tracking-[0.14em] text-foreground-muted" data-i18n="contact.channel.wechat.id_label">
                    {t('contact.channel.wechat.id_label')}
                  </p>
                  <p class="mt-1 text-lg font-semibold text-foreground" translate="no">hisoracc</p>
                </div>

                <div class="rounded-2xl border border-brand-500/15 bg-background px-4 py-3">
                  <p class="text-sm font-semibold text-foreground" data-i18n="contact.channel.priority">
                    {t('contact.channel.priority')}
                  </p>
                  <p class="mt-1 text-xs leading-relaxed text-foreground-muted" data-i18n="contact.channel.priority.desc">
                    {t('contact.channel.priority.desc')}
                  </p>
                </div>
              </div>

              <img
                src="/contact/wechat-qr.jpeg"
                alt="WeChat QR code"
                class="w-full rounded-3xl border border-border bg-background shadow-sm"
                loading="lazy"
              />
            </div>
          </Card>

          <div class="grid gap-4 sm:grid-cols-2">
            {whatsappHref && (
              <a href={whatsappHref} target="_blank" rel="noopener noreferrer" class="block group">
                <Card hover padding="sm" class="h-full border-brand-500/15">
                  <div class="flex items-center gap-3">
                    <div class="w-10 h-10 shrink-0 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500">
                      <Icon name="message-circle" size="sm" />
                    </div>
                    <div class="min-w-0 flex-1">
                      <p class="font-semibold text-sm text-foreground" data-i18n="contact.channel.whatsapp">
                        {t('contact.channel.whatsapp')}
                      </p>
                      <p class="text-xs text-foreground-muted" data-i18n="contact.channel.whatsapp.desc">
                        {t('contact.channel.whatsapp.desc')}
                      </p>
                    </div>
                    <Icon name="arrow-up-right" size="sm" class="text-foreground-muted group-hover:text-brand-500 transition-colors shrink-0" />
                  </div>
                </Card>
              </a>
            )}

            <a href={`mailto:${siteConfig.email}`} class="block group">
              <Card hover padding="sm" class="h-full border-border/80">
                <div class="flex items-center gap-3">
                  <div class="w-10 h-10 shrink-0 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500">
                    <Icon name="mail" size="sm" />
                  </div>
                  <div class="min-w-0 flex-1">
                    <p class="font-semibold text-sm text-foreground" data-i18n="contact.channel.email">
                      {t('contact.channel.email')}
                    </p>
                    <p class="text-xs text-foreground-muted truncate">{siteConfig.email}</p>
                  </div>
                  <Icon name="arrow-up-right" size="sm" class="text-foreground-muted group-hover:text-brand-500 transition-colors shrink-0" />
                </div>
              </Card>
            </a>
          </div>

          <Card padding="sm" class="bg-background border-border/80">
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 shrink-0 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500">
                <Icon name="map-pin" size="sm" />
              </div>
              <div>
                <p class="font-semibold text-sm text-foreground">{siteConfig.address?.city ?? 'Your City'}</p>
                <p class="text-xs text-foreground-muted mt-0.5">
                  <span data-i18n="contact.location.basedIn">{t('contact.location.basedIn')}</span>{' '}
                  {siteConfig.address?.country ?? 'Your Country'}
                </p>
              </div>
            </div>
          </Card>
        </div>

        <div data-reveal data-reveal-delay="1">
          <Card padding="lg" class="h-full border-border/80 bg-background">
            <div class="space-y-6">
              <div class="space-y-2">
                <h2 class="font-display text-xl font-bold text-foreground" data-i18n="contact.form.title">
                  {t('contact.form.title')}
                </h2>
                <p class="text-sm text-foreground-muted" data-i18n="contact.form.subtitle">
                  {t('contact.form.subtitle')}
                </p>
              </div>
              <ContactForm />
            </div>
          </Card>
        </div>
      </div>
    </div>
  </section>
</PageLayout>
