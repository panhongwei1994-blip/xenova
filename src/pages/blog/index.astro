---
import PageLayout from '@/layouts/PageLayout.astro';
import Button from '@/components/ui/form/Button/Button.astro';
import Badge from '@/components/ui/data-display/Badge/Badge.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import { getCollection } from 'astro:content';
import { t } from '@/config/i18n.config';

export const prerender = true;

function getBlogSlug(id: string) {
  return id.replace(/^en\//, '').replace(/\.mdx?$/, '');
}

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => {
    if (a.data.featured !== b.data.featured) return a.data.featured ? -1 : 1;
    return b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf();
  });
---

<PageLayout
  title="Restaurant Growth Blog"
  description="Restaurant growth articles about online customer acquisition, direct ordering systems, and reducing delivery app commission."
  showScrollProgress
>
  <section class="py-[var(--space-section-md)] bg-background-secondary border-b border-border">
    <div class="mx-auto max-w-4xl px-6 text-center flex flex-col items-center gap-5">
      <Badge variant="brand" pill><span data-i18n="blog.badge">{t('blog.badge')}</span></Badge>
      <h1 class="font-display text-4xl font-bold text-foreground md:text-5xl" data-i18n="blog.title">
        {t('blog.title')}
      </h1>
      <p class="max-w-2xl text-lg text-foreground-muted" data-i18n="blog.subtitle">
        {t('blog.subtitle')}
      </p>
    </div>
  </section>

  <section class="py-[var(--space-section-md)]">
    <div class="mx-auto grid max-w-6xl gap-6 px-6 md:grid-cols-2 lg:grid-cols-3">
      {posts.map((post) => (
        <Card variant="elevated" hover padding="lg" href={`/blog/${getBlogSlug(post.id)}`} class="group flex h-full flex-col">
          <div class="mb-4 flex flex-wrap gap-2">
            {post.data.tags.map((tag) => (
              <Badge size="sm" variant="brand">{tag}</Badge>
            ))}
          </div>
          <p class="mb-3 text-xs font-semibold tracking-wide text-foreground-muted">
            {post.data.publishedAt.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
          </p>
          <h2 class="font-display text-xl font-bold text-foreground leading-tight">
            {post.data.title}
          </h2>
          <p class="mt-3 flex-1 text-sm leading-relaxed text-foreground-muted">
            {post.data.description}
          </p>
          <div class="mt-6 inline-flex items-center gap-2 text-sm font-semibold text-brand-500">
            <span data-i18n="blog.readmore">{t('blog.readmore')}</span>
            <Icon name="arrow-right" size="sm" class="transition-transform group-hover:translate-x-1" />
          </div>
        </Card>
      ))}
    </div>
  </section>

  <section class="border-t border-border bg-background-secondary py-12">
    <div class="mx-auto max-w-2xl px-6 text-center">
      <Button href="/contact">
        Contact Hi Sora
        <Icon name="arrow-right" size="sm" />
      </Button>
    </div>
  </section>
</PageLayout>
